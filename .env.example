# Telegram
TELEGRAM_TOKEN=
OWNER_CHAT_ID=

# FatSecret app credentials
FATSECRET_CONSUMER_KEY=
FATSECRET_CONSUMER_SECRET=
# FatSecret user tokens (obtained once via: python -m fatsecret_telegram_bridge.auth_setup)
FATSECRET_ACCESS_TOKEN=
FATSECRET_ACCESS_SECRET=

# LLM
LLM_PROVIDER=anthropic        # anthropic | openai
LLM_MODEL=claude-haiku-4-5
LLM_API_KEY=

# Storage / locale
DB_PATH=fatsecret_telegram_bridge.sqlite3
TZ=Europe/Belgrade

# Meal boundaries (hours, local time)
MEAL_BREAKFAST_START=5
MEAL_LUNCH_START=11
MEAL_DINNER_START=16
MEAL_DINNER_END=22

# Logging and long-polling
LOG_LEVEL=INFO              # DEBUG also logs raw LLM responses
POLL_INTERVAL=0.0           # delay between getUpdates calls, seconds
POLL_TIMEOUT=10             # how long Telegram holds the long-poll connection, seconds
